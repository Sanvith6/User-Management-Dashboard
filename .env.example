# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=userdb
DATABASE_URL=postgresql://postgres:postgres@db:5432/userdb

# Application Configuration
DEBUG=false
APP_NAME=User Management API
APP_VERSION=1.0.0

# API Configuration
API_PREFIX=/api/v1

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000/api/v1

# AWS Configuration (for future deployment)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# CloudWatch Configuration (for future monitoring)
# CLOUDWATCH_LOG_GROUP=/aws/user-management-app
# CLOUDWATCH_LOG_STREAM=backend

# n8n Configuration (for future automation)
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook
